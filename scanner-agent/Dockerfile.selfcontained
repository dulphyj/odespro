# Self-contained Dockerfile - uses Ubuntu instead of MCR for environments
# where MCR (Microsoft Container Registry) is blocked by a proxy.
# Build the binary first: dotnet publish -c Release -r linux-x64 --self-contained true -o publish/linux-x64
FROM ubuntu:22.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libusb-1.0-0 \
        libc6-dev \
        libicu-dev \
        libgdiplus \
        libx11-6 \
        libcups2-dev \
        sane-utils \
        sane-airscan \
        hplip \
        ca-certificates \
        && rm -rf /var/lib/apt/lists/*

# Ensure scanner group exists
RUN groupadd -f scanner && \
    usermod -a -G scanner,root www-data 2>/dev/null || true

RUN if [ -f /etc/sane.d/hpaio.conf ]; then \
        echo "hpaio" >> /etc/sane.d/dll.conf 2>/dev/null || true; \
    fi

EXPOSE 5000

ENV ASPNETCORE_URLS=http://+:5000
ENV ScanSettings__TempFolder=/tmp/scans
ENV SCANNER_PROVIDER=sane
ENV DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1

WORKDIR /app
COPY publish/linux-x64/ .

RUN mkdir -p /tmp/scans /tmp/scans/pdfs /tmp/scans/thumbnails

RUN scanimage -V 2>/dev/null || true

ENTRYPOINT ["./ScannerAgent"]
